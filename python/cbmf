def download_genome_files(species, index, refseq):
    print(f"Initializing genome files for {species}.")
    
    GENOMES_MIRROR = "https://ftp.ncbi.nlm.nih.gov/genomes/all"
    GENOMES_DIRECTORY = f"$HOME/genomes/{species}"
    
    if species == 'mouse':
        LATEST = "GCA_000001635.9_GRCm39"
        URL = f"{GENOMES_MIRROR}/GCA/000/001/635/{LATEST}"
    elif species == 'human':
        LATEST = "GCA_000001405.15_GRCh38"
        URL = f"{GENOMES_MIRROR}/GCA/000/001/405/{LATEST}"
    
    # Utility functions
    def download_file(suffix):
        url = f"{URL}/{LATEST}_full_analysis_set{suffix}"
        dest = f"{GENOMES_DIRECTORY}/{LATEST}_full_analysis_set{suffix}"
        print(f"Downloading {suffix}...")
        subprocess.run(['wget', '-e', 'robots=off', '--no-parent', '--cut-dirs=9', '-q', '-O', dest, url])
    
    def download_and_extract(index_type):
        suffix = f".{index_type}_index.tar.gz"
        url = f"{URL}/{LATEST}_full_analysis_set.fna{suffix}"
        dest = f"{GENOMES_DIRECTORY}/{LATEST}_full_analysis_set.fna{suffix}"
        print(f"Downloading {index_type} index...")
        subprocess.run(['wget', '-e', 'robots=off', '--no-parent', '--cut-dirs=9', '-q', '-O', '-', url], stdout=subprocess.PIPE)
        subprocess.run(['tar', '-xz', '-C', GENOMES_DIRECTORY, '--strip-components=1'])
    
    if index:
        if index == "all":
            for idx in ['bwa', 'bowtie2', 'hisat2', 'fai']:
                download_and_extract(idx)
        else:
            download_and_extract(index)
    
    if refseq:
        if refseq == "all":
            for fmt in ['gtf', 'gff']:
                download_file(f".refseq_annotation.{fmt}.gz")
        else:
            download_file(f".refseq_annotation.{refseq}.gz")
    
    print(f"Completed downloads for {species}.")

def main():
    args = parse_arguments()
    
    if args.command == 'qc':
        run_quality_control(args.input, args.output)
    
    elif args.command == 'align':
        run_alignment(args.input, args.reference, args.output, args.aligner)
    
    elif args.command == 'init':
        download_genome_files(args.species, args.index, args.refseq)
    
    else:
        print("Unknown command.")
        sys.exit(1)

if __name__ == '__main__':
    main()

