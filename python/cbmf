#!/usr/bin/env python3
import argparse
import subprocess
import sys

def parse_arguments():
    parser = argparse.ArgumentParser(
        description='Combinatorial Bioinformatic Meta-Framework (CBMF) Command-Line Tool',
        formatter_class=argparse.ArgumentDefaultsHelpFormatter
    )
    
    # General arguments
    parser.add_argument(
        '--version', 
        action='version', 
        version='CBMF Tool v0.9'
    )
    
    # Command selection
    subparsers = parser.add_subparsers(dest='command')
    subparsers.required = True
    
    # Quality Control Command
    qc_parser = subparsers.add_parser(
        'qc', 
        help='Run quality control tools on sequencing data'
    )
    qc_parser.add_argument(
        '-i', '--input', 
        required=True, 
        help='Input FASTQ file or directory'
    )
    qc_parser.add_argument(
        '-o', '--output', 
        required=True, 
        help='Output directory for QC results'
    )
    
    # Alignment Command
    align_parser = subparsers.add_parser(
        'align', 
        help='Align reads to a reference genome'
    )
    align_parser.add_argument(
        '-i', '--input', 
        required=True, 
        help='Input FASTQ file or directory'
    )
    align_parser.add_argument(
        '-r', '--reference', 
        required=True, 
        help='Path to the reference genome'
    )
    align_parser.add_argument(
        '-o', '--output', 
        required=True, 
        help='Output directory for alignment results'
    )
    align_parser.add_argument(
        '--aligner', 
        choices=['bwa', 'star', 'hisat2', 'bowtie2'],
        default='bwa',
        help='Aligner to use (default: bwa)'
    )
    
    # Initialize Command
    init_parser = subparsers.add_parser(
        'init', 
        help='Initialize and download genome files'
    )
    init_parser.add_argument(
        '-s', '--species', 
        required=True, 
        choices=['mouse', 'human'],
        help='Species (mouse|human)'
    )
    init_parser.add_argument(
        '-i', '--index', 
        choices=['bwa', 'bowtie2', 'hisat2', 'fai', 'all'],
        help='Index type(s) to download (bwa, bowtie2, hisat2, fai) or "all"'
    )
    init_parser.add_argument(
        '-r', '--refseq', 
        choices=['gtf', 'gff', 'all'],
        help='RefSeq file type(s) to download (gtf, gff) or "all"'
    )
    
    return parser.parse_args()

