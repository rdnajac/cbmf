#!/bin/sh

# Default values
GENOMES_MIRROR="https://ftp.ncbi.nlm.nih.gov/genomes/all"
PIPELINE_DIR="seqs_for_alignment_pipelines.ucsc_ids"

GENOMES_DIRECTORY="$HOME/genomes"
SPECIES=""
INDEX=""
REFSEQ=""

# Function to display usage
usage() {
	echo "Usage: $0 -s {mouse|human} [-i {bwa|bowtie|hisat|fai}] [-r {gtf|gff}]"
	echo
	echo "Options:"
	echo "  -s, --species   Species (mouse|human) - Downloads everything for the species"
	echo "  -i, --index     Download specific index type(s) or all if no argument is given (bwa, bowtie, hisat, fai)"
	echo "  -r, --refseq    Download specific RefSeq file type(s) or all if no argument is given (gtf, gff)"
	echo "  -h, --help      Show this help message"
	exit 1
}

usage_and_exit() {
	usage
	exit 1
}

# Parse command-line options
while [[ "$1" != "" ]]; do
	case $1 in
		-s | --species) shift; SPECIES=$1 ;;
		-i | --index)   shift; INDEX=$1 ;;
		-r | --refseq)  shift; REFSEQ=$1 ;;
		-h | --help)    usage ;;
		*) echo "Invalid option: $1" >&2; usage ;;
	esac
	shift
done

# Check for required arguments
if [ -z "$SPECIES" ]; then
	usage_and_exit
fi

# Define species-specific variables
if [ "$SPECIES" = "mouse" ]; then
	LATEST="GCA_000001635.9_GRCm39"
	URL="${GENOMES_MIRROR}/GCA/000/001/635/${LATEST}/${ALIGNMENT_DIR}"
elif [ "$SPECIES" = "human" ]; then
	LATEST="GCA_000001405.15_GRCh38"
	URL="${GENOMES_MIRROR}/GCA/000/001/405/${LATEST}/${ALIGNMENT_DIR}"
else
	echo "Invalid species: $SPECIES" >&2
	exit 1
fi

mkdir -p "${GENOMES_DIRECTORY}/${SPECIES}"

wget_file_to_stdout() {
	local url=$1
	wget -q -O - "$url"
}

# Functions for downloading files
download_file() {
	suffix=$1
	url="${URL}/${LATEST}_full_analysis_set${suffix}"
	dest="${GENOMES_DIRECTORY}/${SPECIES}/${LATEST}_full_analysis_set${suffix}"

	echo "Downloading ${suffix}..."
	wget -e robots=off --no-parent --cut-dirs=9 -q -O "$dest" "$url"
}

download_and_extract() {
	local index_type=$1
	local suffix=".${index_type}_index.tar.gz"
	local url="${URL}/${LATEST}_full_analysis_set.fna${suffix}"
	local dest="${GENOMES_DIRECTORY}/${SPECIES}/${LATEST}_full_analysis_set.fna${suffix}"

	echo "Downloading ${index_type} index..."
	wget -e robots=off --no-parent --cut-dirs=9 -q -O - "$url" | tar -xz -C "${GENOMES_DIRECTORY}/${SPECIES}" --strip-components=1
}

# Perform tasks based on options
if [[ -n "$INDEX" ]]; then
	if [[ "$INDEX" == "all" ]]; then
		for idx in bwa bowtie hisat fai; do
			download_and_extract "$idx"
		done
	else
		download_and_extract "$INDEX"
	fi
elif [[ -n "$REFSEQ" ]]; then
	if [[ "$REFSEQ" == "all" ]]; then
		for fmt in gtf gff; do
			download_file ".refseq_annotation.${fmt}.gz"
		done
	else
		download_file ".refseq_annotation.${REFSEQ}.gz"
	fi
else
	# Download genome file
	download_file ".fna.gz"

  # Download all indices
  for idx in bwa bowtie hisat fai; do
	  download_and_extract "$idx"
  done

  # Download all RefSeq files
  for fmt in gtf gff; do
	  download_file ".refseq_annotation.${fmt}.gz"
  done
fi

echo "Completed downloads for $SPECIES."

