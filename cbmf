#!/bin/bash
# -*- tab-width: 8; encoding: utf-8; -*-
#==============================================================================
## @file cbmf
## @author Ryan Najac <ryan.najac@columbia.edu>
## @copyright Public Domain
## @version 0.9
## @brief Command-line Bioinformatics Meta-Framework
## @details Configures an extensible framework for bioinformatics projects
## @par URL
## https://github.com/rdnajac/cbmf
#===============================================================================

# Safety first!
set -eu
#===============================================================================

# This is the same invoking both `set -o errexit` and `set -o nounset`.
# It causes the script to exit immediately if a command exits with a 
# non-zero status, and treats unset variables error.

# Uncomment to print each command before it is executed. Useful for debugging.
# This is the same as `set -o xtrace` or invoking the script with `bash -x`.
# set -x

# Catch the error in case a pipeline element fails (returns non-zero)
# Note that this does not catch every error, but a script that works
# with `set -o pipefail` will always work without it, while the opposite is not true.
# Note that `set -o pipefail` is not POSIX-compliant, so we can add a check for POSIX mode.
if [ "${POSIXLY_CORRECT:-}" != "" ]; then
	printf "POSIXLY_CORRECT is set; some features may be disabled"
else
	set -o pipefail
	# this does not always work as expected,
	# nor is it POSIX compliant
fi

# Utility functions
#===============================================================================
# Utility functions
err() { printf "\033[1;31mError: %s\033[0m\n" "$1" >&2; }

err_exit() { err "$1"; exit "${2:-1}"; }

# Constants
# ==============================================================================
# The 0th positional parameter is the name of the script itself
# the cd && pwd ensure that the script works even if it is called 
# from a relative directory, symlink, or over ssh
CBMF_DIR=$(cd "$(dirname "$0")" && pwd)

# when we invoke this script across ssh like ssh user@host 'bash -s' < script,
# the script is executed in the home directory of the user, and that is
# correctly captured by the script

export BIN_DIR="${CBMF_DIR}/bin"
export GENOMES_DIR="${CBMF_DIR}/genomes"
export SCRIPTS_DIR="${CBMF_DIR}/scripts"
export MAMBA_EXE="${BIN_DIR}/micromamba"
export MAMBA_ROOT_PREFIX="${CBMF_DIR}/mamba_root"

# micromamba configuration:
# micromamba config append channels bioconda
# micromamba config append channels conda-forge
# micromamba config append channels nodefaults
# micromamba config set channel_priority strict

RETICULATE_MINICONDA_ENABLED=FALSE
# This is only env variable relevant if you are using R with reticulate,
# an R package that allows you to run Python code in R.
# > library(reticulate)
# > os <- import("os")
# R should NOT prompt you to install miniconda

main() {
	# parse command line arguments
	if [ $# -eq 0 ]; then
		usage
		exit 1
	fi
}
main "$@"


# Call main function
align_reads() {
	local aligner="$1" r1_fastq="$2" r2_fastq="$3" reference="$4"
	local align_opts="-p $(nproc) --mm -1 $r1_fastq -2 $r2_fastq -x $reference"
	case "$aligner" in
		hisat2) hisat2 "$align_opts" ;;
		bowtie2) bowtie2 "$align_opts" --dta ;;
		*) err_exit "Invalid aligner: $aligner" ;;
	esac
}

align_to_bam() {
	local aligner="$1" r1_fastq="$2" r2_fastq="$3" reference="$4"
	local bam_file="${r1_fastq%_R1*}_sorted_markdup.bam"
	align_reads "$aligner" "$r1_fastq" "$r2_fastq" "$reference" \
		| samtools sort -n -@ "$(nproc)" - \
		| samtools fixmate -@ "$(nproc)" -m - - \
		| samtools sort -@ "$(nproc)" - \
		| samtools markdup -@ "$(nproc)" - "$bam_file"
}

bam_to_cram() {
	local bam_file="$1"
	local id=$(basename "$bam_file" .bam)
	local cram_file="${id}.cram"
	local reference="/home/ubuntu/genomes/human/GCA_000001405.15_GRCh38_full_analysis_set.fna.bgz"
	samtools view -@"$(nproc)" --cram -T "$reference" "$bam_file" > "$cram_file"
	pr_info "Converted $bam_file to $cram_file"
}

cram_to_bam() {
	local cram_file="$1"
	local id=$(basename "$cram_file" .cram)
	local bam_file="${id}.bam"
	[ -f "$bam_file" ] && mv "$bam_file" "${bam_file}.bak"
	samtools view -@"$(nproc)" --bam "$cram_file" > "$bam_file"
	pr_info "Converted $cram_file to $bam_file"
}

run_fastqc() {
	local out_dir=${1:-fastqc}
	local memsize=4096
	mkdir -p "$out_dir"
	fastqc -t "$(nproc)" --memory "$memsize" --noextract -o "$out_dir" ./*
	pr_info "FastQC analysis completed. Results in $out_dir"
}

cmd_align() {
	local species aligner input_dir output_dir
	while getopts ":s:a:i:o:h" opt; do
		case $opt in
			s) species=$OPTARG ;;
			a) aligner=$OPTARG ;;
			i) input_dir=$OPTARG ;;
			o) output_dir=$OPTARG ;;
			h)
				cmd_align_help
				return 0
				;;
			\?) err_exit "Invalid option: -$OPTARG" ;;
		esac
	done

	[ "$species" = "" ] && err_exit "Species (-s) is required for alignment"
	[ "$aligner" = "" ] && err_exit "Aligner (-a) is required for alignment"
	[ "$input_dir" = "" ] && err_exit "Input directory (-i) is required"
	[ "$output_dir" = "" ] && err_exit "Output directory (-o) is required"

	validate "$species" "$VALID_SPECIES" || err_exit "Invalid species: $species"
	validate "$aligner" "$VALID_ALIGNERS" || err_exit "Invalid aligner: $aligner"

	local reference="$GENOMES_DIR/${species}/${species}_genome"
	mkdir -p "$output_dir"

	for r1_fastq in "$input_dir"/*_R1.fastq.gz; do
		r2_fastq="${r1_fastq/_R1/_R2}"
		[ -f "$r2_fastq" ] || err_exit "Paired read file not found: $r2_fastq"
		align_to_bam "$aligner" "$r1_fastq" "$r2_fastq" "$reference"
	done

	pr_info "Alignment completed. BAM files are in $output_dir"
}


