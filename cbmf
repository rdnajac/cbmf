main() {
	[ $# -eq 0 ] && {
		cmd_help
		exit 1
	}

	local cmd="$1"
	shift
	case "$cmd" in
		align) cmd_align "$@" ;;
		init) init_genome "$@" ;;
		qc) run_fastqc "$@" ;;
		convert)
			[ $# -ne 1 ] && err_exit "Usage: $(basename "$0") convert <file.bam|file.cram>"
			case "$1" in
				*.bam) bam_to_cram "$1" ;;
				*.cram) cram_to_bam "$1" ;;
				*) err_exit "Unknown file type: $1" ;;
			esac
			;;
		help)
			if [ $# -eq 0 ]; then
				cmd_help
			else
				case "$1" in
					align) cmd_align_help ;;
					init | qc | convert) pr_info "$1 help not yet implemented" ;;
					*) err_exit "Unknown command: $1" ;;
				esac
			fi
			;;
		*) err_exit "Unknown command: $cmd" ;;
	esac
}

